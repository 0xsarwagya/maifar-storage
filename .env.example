DATABASE_URL=postgres://postgres:postgres@localhost:5432/maifar
# Postgres over TLS with private/self-signed CA (e.g. RDS or corporate CA):
# DATABASE_TLS_CA_FILE=/path/to/ca.pem
# Or dev-only (mitm risk): DATABASE_TLS_INSECURE=true

# Apply schema.sql on startup (default on). Set false to skip if you manage schema elsewhere.
# AUTO_MIGRATE=false

# MQTT: plain mqtt + 1883 by default. Set MQTT_SSL=true (or MQTT_TLS=true) for mqtts + default 8883.
# OR MQTT_SERVERS JSON array, OR MQTT_URL
MQTT_HOST=mqtt.maifar.actimi.com
MQTT_PORT=1883
# Secured broker (MQTTS):
# MQTT_SSL=true
# MQTT_PORT=8883
# Trust a private / self-signed CA (PEM file path), or temporarily:
# MQTT_TLS_INSECURE=true
# MQTT_TLS_REJECT_UNAUTHORIZED=false
# MQTT_TLS_CA_FILE=/path/to/ca-bundle.pem

# Multiple brokers (iterated on reconnect); if set, MQTT_HOST / MQTT_PORT are ignored
# MQTT_SERVERS=[{"host":"broker1.example.com","port":8883,"protocol":"mqtts"},{"host":"broker2.example.com","port":1883}]

# Full URL (if set, MQTT_HOST / MQTT_PORT / MQTT_SSL / MQTT_SERVERS are ignored)
# MQTT_URL=mqtts://mqtt.maifar.actimi.com:8883

MQTT_USERNAME=
MQTT_PASSWORD=
# MQTT_CLIENT_ID=maifar-storage-prod-1
# MQTT_SUBSCRIBE_QOS=1

MQTT_TOPICS=devices/+/telemetry,#

HTTP_PORT=3000
# Browser / SPA CORS (default *). Example: CORS_ORIGIN=https://myapp.com
# CORS_ORIGIN=
# Startup keepalive ping (enabled by default). Disable with KEEPALIVE_ENABLED=false
# KEEPALIVE_ENABLED=false
# PING_URL=https://maifar-storage.onrender.com/health
# PING_CRON=*/20 * * * * *
# Forward normalized FHIR payloads to Ovok ingest API
# OVOK_INGEST_ENABLED=true
# OVOK_INGEST_BASE_URL=https://api.dev.ovok.com
# OVOK_INGEST_API_KEY=
# OVOK_INGEST_API_KEY_HEADER=x-api-key
# OVOK_INGEST_TIMEOUT_MS=10000
BATCH_MAX=100
FLUSH_INTERVAL_MS=1000

# DEVICE_ID_TOPIC_REGEX=^devices/([^/]+)/
# Multiple shapes: one regex with alternation, e.g. ^(?:devices/([^/]+)/|MC01/Server/([^/]+))$
# DEVICE_ID_JSON_KEY=deviceId
# Skip storage for device IDs starting with any of these prefixes
# Default is Client- when unset.
# SKIP_DEVICE_ID_PREFIXES=Client-,internal-test-

# IANA zone for /devices local timestamps when ?timezone= is not passed (else uses TZ, else UTC)
# DISPLAY_TIMEZONE=Europe/Berlin
