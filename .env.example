DATABASE_URL=postgres://postgres:postgres@localhost:5432/maifar

# Broker URL without credentials (recommended when using MQTT_USERNAME / MQTT_PASSWORD)
MQTT_URL=mqtts://mqtt.maifar.actimi.com:8883

# Optional: MQTT authentication (username required to send a password to the broker)
MQTT_USERNAME=
MQTT_PASSWORD=
# Optional: fixed client id (otherwise the client library generates one)
# MQTT_CLIENT_ID=maifar-storage-prod-1

# Alternative: embed user and password in the URL (encode special characters)
# MQTT_URL=mqtts://USER:PASSWORD@mqtt.maifar.actimi.com:8883

MQTT_TOPICS=devices/+/telemetry,#

HTTP_PORT=3000
BATCH_MAX=100
FLUSH_INTERVAL_MS=1000

# Optional: capture group 1 = device id (default matches devices/{id}/...)
DEVICE_ID_TOPIC_REGEX=^devices/([^/]+)/

# Optional: read device id from JSON when topic regex does not match
# DEVICE_ID_JSON_KEY=deviceId
