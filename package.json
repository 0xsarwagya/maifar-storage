{
  "name": "maifar-storage",
  "version": "1.0.0",
  "description": "MQTT JSON ingest → PostgreSQL batch flush + HTTP export API (Bun)",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:migrate": "bun run scripts/migrate.ts",
    "ping:keepalive": "bun run scripts/keepalive-ping.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:smoke": "bun test tests/smoke",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "mqtt": "^5.10.3",
    "node-cron": "^4.2.1",
    "pino": "^9.13.1",
    "pino-pretty": "^13.1.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "aedes": "^1.0.2"
  }
}
